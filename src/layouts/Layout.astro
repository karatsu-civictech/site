---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'シビックテック唐津',
  description = '佐賀県唐津市を拠点に、テクノロジーとデータで地域課題に取り組む市民の集まりです。',
} = Astro.props;

const fullTitle =
  title === 'シビックテック唐津' ? title : `${title}｜シビックテック唐津`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="ja_JP" />

    <!-- Google Analytics 4 -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-RM5801F92B"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() { dataLayer.push(arguments); }
      gtag('js', new Date());
      gtag('config', 'G-RM5801F92B');
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="brand">
          <span class="brand-text">シビックテック</span>
          <span class="brand-mark">唐津</span>
        </a>
        <nav class="site-nav">
          <a href="/#about">団体とは</a>
          <a href="/#apps">アプリ</a>
          <a href="/#activity">活動</a>
          <a href="/#join">参加・お問い合わせ</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div>
          <p class="footer-brand">シビックテック唐津</p>
          <p class="footer-note">
            佐賀県唐津市 / Karatsu Civic Tech
          </p>
        </div>
        <nav class="footer-links">
          <a href="https://github.com/karatsu-civictech" target="_blank" rel="noopener">
            GitHub
          </a>
          <a href="/#join">お問い合わせ</a>
        </nav>
        <p class="copyright">
          © {new Date().getFullYear()} シビックテック唐津
          <span class="privacy-note">／ サイト改善のためアクセス解析（Google Analytics）を使用しています。</span>
        </p>
      </div>
    </footer>

    <style is:global>
      :root {
        --bg: #f7f9fb;
        --surface: #ffffff;
        --ink: #14323f;
        --ink-soft: #4a6573;
        --brand: #0f7b8a;
        --brand-dark: #0a5b66;
        --accent: #f2a541;
        --border: #e2eaef;
        --radius: 14px;
        --maxw: 1080px;
        --font: system-ui, -apple-system, 'Hiragino Kaku Gothic ProN',
          'Noto Sans JP', Meiryo, sans-serif;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: var(--font);
        color: var(--ink);
        background: var(--bg);
        line-height: 1.75;
        -webkit-font-smoothing: antialiased;
      }

      a {
        color: var(--brand-dark);
      }

      .container {
        width: 100%;
        max-width: var(--maxw);
        margin-inline: auto;
        padding-inline: 1.25rem;
      }

      /* Header */
      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--border);
      }
      .header-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        min-height: 64px;
        flex-wrap: wrap;
      }
      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        text-decoration: none;
        color: var(--ink);
        font-weight: 700;
      }
      .brand-mark {
        background: var(--brand);
        color: #fff;
        border-radius: 8px;
        padding: 0.15rem 0.5rem;
        font-size: 0.95rem;
        letter-spacing: 0.05em;
      }
      .brand-text {
        font-size: 1.05rem;
      }
      .site-nav {
        display: flex;
        gap: 1.25rem;
        flex-wrap: wrap;
      }
      .site-nav a {
        text-decoration: none;
        color: var(--ink-soft);
        font-size: 0.95rem;
        font-weight: 600;
      }
      .site-nav a:hover {
        color: var(--brand-dark);
      }

      /* Footer */
      .site-footer {
        margin-top: 4rem;
        background: var(--ink);
        color: #d7e3e8;
      }
      .footer-inner {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding-block: 2rem;
      }
      .footer-brand {
        margin: 0;
        font-weight: 700;
        color: #fff;
      }
      .footer-note {
        margin: 0.25rem 0 0;
        font-size: 0.85rem;
        color: #9fb6bf;
      }
      .footer-links {
        display: flex;
        gap: 1.25rem;
      }
      .footer-links a {
        color: #d7e3e8;
        text-decoration: none;
        font-weight: 600;
      }
      .footer-links a:hover {
        color: #fff;
      }
      .copyright {
        width: 100%;
        margin: 0;
        font-size: 0.8rem;
        color: #7d97a1;
      }
    </style>
  </body>
</html>
