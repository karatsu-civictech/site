---
import Layout from '../layouts/Layout.astro';
import { apps, STATUS_LABEL } from '../data/apps.ts';

// 公開状況で並べ替え（公開中 → 開発中 → 構想中）
const order = { live: 0, wip: 1, planned: 2 } as const;
const sortedApps = [...apps].sort((a, b) => order[a.status] - order[b.status]);
---

<Layout>
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-inner">
      <p class="eyebrow">佐賀県唐津市 / Karatsu Civic Tech</p>
      <h1>
        テクノロジーとデータで、<br />
        唐津の「気になる」を動かす。
      </h1>
      <p class="lead">
        シビックテック唐津は、市民・エンジニア・デザイナー・行政に関心のある人が集まり、
        地域の課題やデータを <strong>誰でも使えるWebアプリやMap</strong> に変えていく
        ボランティアの集まりです。
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href="#apps">アプリを見る</a>
        <a class="btn btn-ghost" href="#join">活動に参加する</a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="section">
    <div class="container">
      <h2>シビックテックって？</h2>
      <p class="section-lead">
        シビックテック（Civic Tech）は、<strong>シビック（市民）</strong>と
        <strong>テック（技術）</strong>を掛け合わせた言葉。
        地域に住む人が、それぞれの得意技を持ち寄って、まちの課題や疑問に
        自分たちの手で取り組む活動です。
      </p>
      <div class="feature-grid">
        <div class="feature">
          <span class="feature-icon">📊</span>
          <h3>データを開く</h3>
          <p>
            議会の記録や行政のオープンデータを、見やすく・使いやすい形に整え、
            誰でもアクセスできるようにします。
          </p>
        </div>
        <div class="feature">
          <span class="feature-icon">🛠️</span>
          <h3>道具をつくる</h3>
          <p>
            「あったら便利」を小さなWebアプリにして公開。完璧でなくても、
            まず作って・使って・改善していきます。
          </p>
        </div>
        <div class="feature">
          <span class="feature-icon">🤝</span>
          <h3>みんなで関わる</h3>
          <p>
            エンジニアでなくても大丈夫。アイデア・地域の知識・デザイン・
            データ集めなど、関わり方はいろいろ。
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Apps -->
  <section id="apps" class="section section-tint">
    <div class="container">
      <h2>アプリ・データツール</h2>
      <p class="section-lead">
        シビックテック唐津が公開しているWebアプリです。
      </p>
      <div class="app-grid">
        {
          sortedApps.map((app) => (
            <article class={`app-card status-${app.status}`}>
              <div class="app-card-head">
                <span class="app-icon">{app.icon ?? '🧩'}</span>
                <span class={`badge badge-${app.status}`}>
                  {STATUS_LABEL[app.status]}
                </span>
              </div>
              <h3>{app.title}</h3>
              <p>{app.description}</p>
              <div class="app-card-foot">
                {app.status === 'live' ? (
                  <a class="app-link" href={`/${app.path}`}>
                    開く →
                  </a>
                ) : (
                  <span class="app-path">/{app.path}</span>
                )}
                {app.repo && (
                  <a
                    class="repo-link"
                    href={`https://github.com/civictech-karatsu/${app.repo}`}
                    target="_blank"
                    rel="noopener"
                  >
                    GitHub
                  </a>
                )}
              </div>
            </article>
          ))
        }
      </div>
      <p class="apps-note">
        作ってみたいアプリのアイデアがありますか？
        <a href="#join">ぜひ声をかけてください。</a>
      </p>
    </div>
  </section>

  <!-- Activity -->
  <section id="activity" class="section">
    <div class="container">
      <h2>活動の進め方</h2>
      <ol class="steps">
        <li>
          <h3>気になる課題・データを持ち寄る</h3>
          <p>「これ調べてみたい」「このデータ見にくい」から始まります。</p>
        </li>
        <li>
          <h3>小さく作る</h3>
          <p>まずは最小限のかたちで形にして、実際に触れるようにします。</p>
        </li>
        <li>
          <h3>公開して、使いながら良くする</h3>
          <p>このサイトから公開し、フィードバックを受けて少しずつ育てます。</p>
        </li>
      </ol>
    </div>
  </section>

  <!-- Join / Contact -->
  <section id="join" class="section section-cta">
    <div class="container cta-inner">
      <h2>参加・お問い合わせ</h2>
      <p class="section-lead">
        メンバー募集中です。プログラミングの経験は問いません。
        唐津のまちに関心がある方、データやアプリづくりに興味がある方、
        お気軽にご連絡ください。
      </p>
      <div class="cta-actions">
        <a
          class="btn btn-primary"
          href="https://github.com/civictech-karatsu"
          target="_blank"
          rel="noopener"
        >
          GitHub を見る
        </a>
      </div>
      <p class="contact-mail">
        メール：<a href="mailto:ps0139hk@gmail.com">ps0139hk@gmail.com</a>
      </p>
      <p class="cta-note">
        ※ SNS・お問い合わせフォーム等の窓口は準備中です。
      </p>
    </div>
  </section>

  <style>
    /* Hero */
    .hero {
      background: linear-gradient(160deg, #0f7b8a 0%, #0a5b66 60%, #094a54 100%);
      color: #eaf6f8;
    }
    .hero-inner {
      padding-block: clamp(3rem, 8vw, 6rem);
    }
    .eyebrow {
      margin: 0 0 1rem;
      font-size: 0.85rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: #9fe0e8;
      font-weight: 700;
    }
    .hero h1 {
      margin: 0;
      font-size: clamp(1.9rem, 5vw, 3.1rem);
      line-height: 1.3;
      letter-spacing: 0.01em;
    }
    .hero .lead {
      margin: 1.5rem 0 0;
      max-width: 42rem;
      font-size: clamp(1rem, 2.2vw, 1.15rem);
      color: #d4eef1;
    }
    .hero .lead strong {
      color: #fff;
    }
    .hero-actions {
      margin-top: 2rem;
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }

    /* Buttons */
    .btn {
      display: inline-block;
      padding: 0.7rem 1.4rem;
      border-radius: 999px;
      font-weight: 700;
      text-decoration: none;
      font-size: 0.95rem;
      transition: transform 0.12s ease, box-shadow 0.12s ease;
    }
    .btn:hover {
      transform: translateY(-1px);
    }
    .btn-primary {
      background: var(--accent);
      color: #3a2a06;
      box-shadow: 0 6px 16px rgba(242, 165, 65, 0.35);
    }
    .btn-ghost {
      background: rgba(255, 255, 255, 0.12);
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.4);
    }
    .section-cta .btn-ghost {
      background: transparent;
      color: var(--brand-dark);
      border-color: var(--brand);
    }

    /* Sections */
    .section {
      padding-block: clamp(2.5rem, 6vw, 4.5rem);
    }
    .section-tint {
      background: #eef5f7;
    }
    .section h2 {
      margin: 0 0 0.75rem;
      font-size: clamp(1.5rem, 3.5vw, 2rem);
    }
    .section-lead {
      margin: 0 0 2rem;
      max-width: 46rem;
      color: var(--ink-soft);
    }
    .section-lead strong {
      color: var(--ink);
    }
    code {
      background: rgba(15, 123, 138, 0.1);
      padding: 0.1rem 0.4rem;
      border-radius: 6px;
      font-size: 0.9em;
    }

    /* Feature grid */
    .feature-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1.25rem;
    }
    .feature {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.5rem;
    }
    .feature-icon {
      font-size: 1.8rem;
    }
    .feature h3 {
      margin: 0.75rem 0 0.4rem;
      font-size: 1.1rem;
    }
    .feature p {
      margin: 0;
      color: var(--ink-soft);
      font-size: 0.95rem;
    }

    /* App cards */
    .app-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1.25rem;
    }
    .app-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.5rem;
      display: flex;
      flex-direction: column;
    }
    .app-card.status-planned {
      opacity: 0.92;
      border-style: dashed;
    }
    .app-card-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .app-icon {
      font-size: 1.9rem;
    }
    .app-card h3 {
      margin: 0.75rem 0 0.5rem;
      font-size: 1.15rem;
    }
    .app-card p {
      margin: 0 0 1.25rem;
      color: var(--ink-soft);
      font-size: 0.95rem;
      flex-grow: 1;
    }
    .app-card-foot {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.75rem;
    }
    .app-link {
      font-weight: 700;
      text-decoration: none;
    }
    .app-path {
      font-family: ui-monospace, monospace;
      font-size: 0.85rem;
      color: var(--ink-soft);
    }
    .repo-link {
      font-size: 0.85rem;
      color: var(--ink-soft);
      text-decoration: none;
    }
    .repo-link:hover {
      color: var(--brand-dark);
    }
    .badge {
      font-size: 0.72rem;
      font-weight: 700;
      padding: 0.2rem 0.6rem;
      border-radius: 999px;
      letter-spacing: 0.03em;
    }
    .badge-live {
      background: #d8f3df;
      color: #1c7a3d;
    }
    .badge-wip {
      background: #fff0d6;
      color: #9a6b12;
    }
    .badge-planned {
      background: #e7edf0;
      color: #5a727d;
    }
    .apps-note {
      margin-top: 2rem;
      color: var(--ink-soft);
    }

    /* Steps */
    .steps {
      list-style: none;
      counter-reset: step;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 1rem;
    }
    .steps li {
      counter-increment: step;
      position: relative;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1.25rem 1.5rem 1.25rem 4rem;
    }
    .steps li::before {
      content: counter(step);
      position: absolute;
      left: 1.25rem;
      top: 1.25rem;
      width: 1.8rem;
      height: 1.8rem;
      background: var(--brand);
      color: #fff;
      border-radius: 50%;
      display: grid;
      place-items: center;
      font-weight: 700;
    }
    .steps h3 {
      margin: 0 0 0.25rem;
      font-size: 1.05rem;
    }
    .steps p {
      margin: 0;
      color: var(--ink-soft);
      font-size: 0.95rem;
    }

    /* CTA */
    .section-cta {
      background: #eef5f7;
    }
    .cta-actions {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .contact-mail {
      margin-top: 1.25rem;
      font-weight: 600;
    }
    .contact-mail a {
      color: var(--brand-dark);
    }
    .cta-note {
      margin-top: 0.5rem;
      font-size: 0.85rem;
      color: var(--ink-soft);
    }
  </style>
</Layout>
